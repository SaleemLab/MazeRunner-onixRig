                      </Expression>
                      <Expression xsi:type="Combinator">
                        <Combinator xsi:type="rx:WithLatestFrom" />
                      </Expression>
                      <Expression xsi:type="scr:ExpressionTransform">
                        <scr:Expression>new(Item1.Item1 as Wheel, Item1.Item2 as LastSyncPulseTime, Item1.Item3 as ArduinoTime, Item1.Item4 as BonsaiTime, Item2 as QuadState)</scr:Expression>
                      </Expression>
                      <Expression xsi:type="rx:BehaviorSubject">
