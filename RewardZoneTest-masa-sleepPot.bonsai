        <Description>Harp based Camera Trigger

Press Shift + L to start camera (start experiment)
Press Shift + T to stop camera (end experiment)</Description>
        <Workflow>
          <Nodes>
            <Expression xsi:type="Annotation">
              <Name>2</Name>
              <Text><![CDATA[]]></Text>
            </Expression>
            <Expression xsi:type="ExternalizedMapping">
              <Property Name="Camera0Frequency" />
            </Expression>
            <Expression xsi:type="beh:CreateMessage">
              <harp:MessageType>Write</harp:MessageType>
              <harp:Payload xsi:type="beh:CreateCamera0FrequencyPayload">
                <beh:Camera0Frequency>60</beh:Camera0Frequency>
              </harp:Payload>
            </Expression>
            <Expression xsi:type="Annotation">
              <Name>3</Name>
              <Text><![CDATA[]]></Text>
            </Expression>
            <Expression xsi:type="Combinator">
